# انسخ هذا الملف إلى .env.local واملأ القيم الحقيقية.
# لا تضع المفاتيح الحقيقية في الكود أو في Git — ملف .env.local مُتجاهَل تلقائيًا.

# مفتاح Resend API — من https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# البريد الذي تصل إليه رسائل نموذج التواصل
CONTACT_EMAIL=alsawaedlawfirm@gmail.com

# (اختياري) عنوان المُرسِل — يجب أن يكون من نطاق موثّق في Resend.
# اتركه فارغًا لاستخدام نطاق الاختبار onboarding@resend.dev
# مثال: CONTACT_FROM="مكتب السواعد <no-reply@your-domain.com>"
CONTACT_FROM=
